PORT=4000
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/livcare

JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
DEFAULT_ADMIN_EMAIL=helpdesklivcare@gmail.com
DEFAULT_ADMIN_PASSWORD=Livcare@123

# SMTP (required in production for email verification / password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@yourdomain.com
SMTP_FROM=
EMAIL_BRAND_NAME=Livcare Medical Systems

# SMS provider: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# SMS provider: MSG91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_COUNTRY=91

# WhatsApp provider: Twilio WhatsApp OR Meta Cloud API
TWILIO_WHATSAPP_FROM=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
ENABLE_WHATSAPP_NOTIFICATIONS=false

# Automatic notification retries
NOTIFICATION_RETRY_WORKER_ENABLED=true
NOTIFICATION_RETRY_INTERVAL_MS=60000
NOTIFICATION_RETRY_BATCH_SIZE=20

# Order auto-cancel worker (stale unpaid online orders)
ORDER_AUTO_CANCEL_WORKER_ENABLED=true
ORDER_AUTO_CANCEL_INTERVAL_MS=60000
ORDER_AUTO_CANCEL_CUTOFF_MINUTES=15
ORDER_AUTO_CANCEL_BATCH_SIZE=20

EMAIL_VERIFY_TOKEN_EXPIRES_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_CAPTURE_MODE=auto
AUTO_REFUND_ENABLED=false

# Payment reconciliation worker
PAYMENT_RECONCILE_WORKER_ENABLED=true
PAYMENT_RECONCILE_INTERVAL_MS=60000
PAYMENT_RECONCILE_CUTOFF_MINUTES=15
PAYMENT_RECONCILE_BATCH_SIZE=20

# Refund retry worker
REFUND_RETRY_WORKER_ENABLED=true
REFUND_RETRY_INTERVAL_MS=120000
REFUND_RETRY_DELAY_MINUTES=15
REFUND_RETRY_BATCH_SIZE=10
REFUND_RETRY_MAX_ATTEMPTS=5

IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Firebase (Admin SDK)
# Option A: point to a service account JSON file (recommended for local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=credentials/firebase-service-account.json
# Option B: set individual values (useful for deployments)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Web push notification click action (optional)
WEBPUSH_CLICK_ACTION=

CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
